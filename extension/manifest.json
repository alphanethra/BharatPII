{
  "manifest_version": 3,
  "name": "BharatPII Shield",
  "version": "1.0",
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1:8000/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
